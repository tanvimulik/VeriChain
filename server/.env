# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Configuration
# Get your connection string from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string and replace <password> with your actual password
MONGODB_URI=mongodb://vidhi3121:vidhi%40123@ac-baz27az-shard-00-00.xnh8888.mongodb.net:27017,ac-baz27az-shard-00-01.xnh8888.mongodb.net:27017,ac-baz27az-shard-00-02.xnh8888.mongodb.net:27017/veri_chain?ssl=true&retryWrites=true&w=majority&authSource=admin
# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secret (Change this to a random string in production!)
JWT_SECRET=your_jwt_secret_key_here_change_in_production_use_random_64_char_string

# Razorpay Configuration (Get from https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Google Maps API (Get from https://console.cloud.google.com/)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# eNAM API - Government Mandi Prices (Get from https://data.gov.in/)
ENAM_API_KEY=your_enam_api_key
ENAM_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# AWS S3 Configuration (Optional - for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=farmconnect-uploads

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=3
DEFAULT_TRANSPORT_COST_PER_KM=2
DEFAULT_STORAGE_COST_PER_KG_DAY=0.5

# Client URL (for CORS)
CLIENT_URL=http://localhost:8000
